# Copy this file to .env and fill in your values
# =============================================
# All providers listed here are FREE to use.

# ── Option 1: Ollama (100% Local — no API key) ──────────────────────────────
# Download Ollama from: https://ollama.com/download
# Then run: ollama pull llama4:scout && ollama pull llama4:maverick
# Or for CPU-only: ollama pull llama3.2 && ollama pull mistral
#
# Override default model selections (optional):
OLLAMA_FAST_MODEL=llama4:scout
OLLAMA_POWERFUL_MODEL=llama4:maverick
# CPU-only fallback (set manually if no GPU):
# OLLAMA_FAST_MODEL=llama3.2
# OLLAMA_POWERFUL_MODEL=mistral

# ── Option 2: Groq Cloud (fastest free inference) ───────────────────────────
# Get free key at: https://console.groq.com (no credit card)
GROQ_API_KEY=your_groq_key_here

# ── Option 3: Google Gemini (Google AI Studio free) ─────────────────────────
# Get free key at: https://aistudio.google.com (no credit card)
GOOGLE_API_KEY=your_google_key_here

# ── LangSmith Observability (free tier — optional but impressive) ────────────
# Get free key at: https://smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=research-intelligence-system
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── ChromaDB Cache Settings ──────────────────────────────────────────────────
# Path where ChromaDB stores research cache (default: output/chromadb)
CHROMA_DB_PATH=output/chromadb
# Similarity threshold for cache hits (0.0–1.0, default 0.85)
CACHE_SIMILARITY_THRESHOLD=0.85
